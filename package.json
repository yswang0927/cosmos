{
  "name": "@cosmos.gl/graph",
  "version": "3.0.0-beta.2",
  "description": "GPU-based force graph layout and rendering",
  "jsdelivr": "dist/index.min.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "repository": "git://github.com/cosmos.gl/graph.git",
  "type": "module",
  "files": [
